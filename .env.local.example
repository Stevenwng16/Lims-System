# Supabase auth backend (lib/auth/supabase.ts). Leave these unset to run the
# app on the in-memory mock auth (demo accounts on the login page).
#
# Hosted project: values from https://supabase.com/dashboard → Project
# Settings → API. Local dev: run `npx supabase start` in lims-supabase/ and
# use the URL + anon key it prints (defaults below).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key>

# Base URL of this app; used for password-reset redirects.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
