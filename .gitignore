# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files: the app's root .env.local is deliberately committed so the team
# connects to Supabase on a fresh clone (anon key only — it is the publishable
# client key; never put the service_role key, DB password or access tokens in
# it). All other env files stay ignored: lims-supabase/.env.local carries a
# personal Supabase access token.
.env*
!/.env.local
!/.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
